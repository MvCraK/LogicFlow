{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "clean": {
      "outputs": []
    },
    "build:cjs": {
      "dependsOn": ["^build"],
      "outputs": ["lib/**", "src/style/raw.ts"]
    },
    "build:esm": {
      "dependsOn": ["^build"],
      "outputs": ["es/**", "src/style/raw.ts"]
    },
    "build:umd": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "src/style/raw.ts"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["lib/**", "es/**", "src/style/raw.ts"]
    },
    "build:all": {
      "dependsOn": ["^build"],
      "outputs": ["lib/**", "es/**", "dist/**", "src/style/raw.ts"]
    }
  }
}
